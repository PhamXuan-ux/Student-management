@model List<Student.Management.Domain.Entities.ApplicationUser>
@{
    ViewData["Title"] = "Users Management";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
    var currentRole = ViewBag.CurrentRole as string ?? "";
    var roles = ViewBag.Roles as List<string> ?? new List<string>();
}

<div class="page-header">
    <div class="page-title">
        <h1>Users Management</h1>
        <p>Manage Admins, Teachers, and Students</p>
    </div>
    <div class="table-actions">
        <button class="btn btn-primary btn-add" onclick="openUserModal()">
            <i class="bi bi-plus"></i> Add New User
        </button>
    </div>
</div>

<!-- Filter Tabs -->
<div style="display: flex; gap: 0.5rem; margin-bottom: 1.5rem; border-bottom: 1px solid var(--border); padding-bottom: 1rem;">
    <a href="/Admin/Admin/Users" class="btn btn-outline @(string.IsNullOrEmpty(currentRole) ? "active" : "")" style="text-decoration: none;">All Users</a>
    @foreach (var role in roles)
    {
        <a href="/Admin/Admin/Users?role=@role" class="btn btn-outline @(currentRole == role ? "active" : "")" style="text-decoration: none;">@role Users</a>
    }
</div>

<div class="table-container">
    <div class="table-header">
        <h3>@(string.IsNullOrEmpty(currentRole) ? "All Users" : $"{currentRole} Users") (@Model.Count)</h3>
        <div class="search-box">
            <i class="bi bi-search"></i>
            <input type="text" id="userSearch" placeholder="Search users...">
        </div>
    </div>

    @if (Model.Any())
    {
        <table class="table">
            <thead>
                <tr>
                    <th>User</th>
                    <th>Contact</th>
                    <th>Role</th>
                    <th>Created</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var user in Model)
                {
                    <tr>
                        <td>
                            <div style="display: flex; align-items: center; gap: 0.75rem;">
                                <!-- ĐÃ XÓA style="background: #2563eb" -->
                                <div class="avatar">
                                    @(user.FullName?.Length > 0 ? user.FullName.Substring(0, 1).ToUpper() : "U")
                                </div>
                                <div>
                                    <div style="font-weight: 500;">@user.FullName</div>
                                    <div style="font-size: 0.75rem; color: var(--text-secondary);">ID: @user.Id</div>
                                </div>
                            </div>
                        </td>
                        <td>
                            <div style="font-weight: 500;">@user.Email</div>
                            <div style="font-size: 0.75rem; color: var(--text-secondary);">@(user.PhoneNumber ?? "No phone")</div>
                        </td>
                        <td>
                            <span class="role-badge @(user.Role?.ToLower() ?? "student")">@user.Role</span>
                        </td>
                        <td>@user.DateCreated.ToString("dd/MM/yyyy")</td>
                        <td>
                            <div class="action-buttons">
                                <button class="btn-icon btn-edit" onclick="editUser('@user.Id')"><i class="bi bi-pencil"></i></button>
                                <button class="btn-icon btn-delete" onclick="deleteUser('@user.Id')"><i class="bi bi-trash"></i></button>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
    else
    {
        <div class="empty-state">
            <i class="bi bi-people"></i>
            <h3>No Users Found</h3>
            <p>There are no users matching your criteria.</p>
        </div>
    }
</div>

<!-- User Modal -->
<div id="userModal" class="modal">
    <div class="modal-content">
        <div class="modal-header">
            <h3 id="userModalTitle">Add New User</h3>
            <button class="btn-close" onclick="document.getElementById('userModal').style.display='none'"><i class="bi bi-x"></i></button>
        </div>
        <div class="modal-body">
            <input type="hidden" id="userId">
            <div class="form-group">
                <label class="form-label">Full Name *</label>
                <input type="text" id="userFullName" class="form-control" required>
            </div>
            <div class="form-group">
                <label class="form-label">Email *</label>
                <input type="email" id="userEmail" class="form-control" required>
            </div>
            <div class="form-group">
                <label class="form-label">Phone Number</label>
                <input type="text" id="userPhone" class="form-control">
            </div>
            <div class="form-group">
                <label class="form-label">Role *</label>
                <select id="userRole" class="form-select form-control">
                    <option value="Student">Student</option>
                    <option value="Teacher">Teacher</option>
                    <option value="Admin">Admin</option>
                </select>
            </div>
            <div class="form-group">
                <label class="form-label">Address</label>
                <textarea id="userAddress" class="form-control form-textarea"></textarea>
            </div>
        </div>
        <div class="modal-footer">
            <button class="btn btn-outline" onclick="document.getElementById('userModal').style.display='none'">Cancel</button>
            <button class="btn btn-primary" onclick="saveUser()">Save</button>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // 1. Search Client-side
        document.getElementById('userSearch')?.addEventListener('input', function(e) {
            const term = e.target.value.toLowerCase();
            document.querySelectorAll('.table tbody tr').forEach(row => {
                const text = row.innerText.toLowerCase();
                row.style.display = text.includes(term) ? '' : 'none';
            });
        });

        function openUserModal() {
            document.getElementById('userModal').classList.add('show');
            document.getElementById('userModal').style.display = 'flex';
            document.getElementById('userModalTitle').innerText = 'Add New User';
            document.getElementById('userId').value = '';
            document.getElementById('userFullName').value = '';
            document.getElementById('userEmail').value = '';
            document.getElementById('userEmail').disabled = false;
            document.getElementById('userPhone').value = '';
            document.getElementById('userRole').value = 'Student';
            document.getElementById('userAddress').value = '';
        }

        async function saveUser() {
            const id = document.getElementById('userId').value;
            const data = {
                id: id || null,
                fullName: document.getElementById('userFullName').value,
                email: document.getElementById('userEmail').value,
                phoneNumber: document.getElementById('userPhone').value,
                role: document.getElementById('userRole').value,
                address: document.getElementById('userAddress').value
            };

            if(!data.fullName || !data.email) { alert("Full Name and Email are required!"); return; }

            const url = id ? '/Admin/Admin/UpdateUser' : '/Admin/Admin/CreateUser';

            try {
                const res = await fetch(url, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(data)
                });
                const result = await res.json();
                if(result.success) { location.reload(); }
                else { alert(result.message); }
            } catch(e) { alert('Error saving user: ' + e); }
        }

        async function editUser(id) {
            try {
                const res = await fetch(`/Admin/Admin/GetUser?id=${id}`);
                const result = await res.json();
                if(result.success) {
                    openUserModal();
                    document.getElementById('userModalTitle').innerText = 'Edit User';
                    const u = result.data;
                    document.getElementById('userId').value = u.id;
                    document.getElementById('userFullName').value = u.fullName;
                    document.getElementById('userEmail').value = u.email;
                    document.getElementById('userEmail').disabled = true;
                    document.getElementById('userPhone').value = u.phoneNumber;
                    document.getElementById('userRole').value = u.role;
                    document.getElementById('userAddress').value = u.address;
                } else { alert(result.message); }
            } catch(e) { alert("Error loading user data"); }
        }

        async function deleteUser(id) {
            if(confirm('Are you sure you want to delete this user?')) {
                try {
                    const res = await fetch(`/Admin/Admin/DeleteUser?id=${id}`, { method: 'POST' });
                    const result = await res.json();
                    if(result.success) location.reload();
                    else alert(result.message);
                } catch(e) { alert("Error deleting user"); }
            }
        }
    </script>
}