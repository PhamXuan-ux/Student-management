@model List<Student.Management.Domain.Entities.Department>
@{
    ViewData["Title"] = "Departments Management";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="page-header">
    <div class="page-title">
        <h1>Departments</h1>
        <p>Manage university faculties and departments</p>
    </div>
    <div class="table-actions">
        <button class="btn btn-primary btn-add" onclick="openModal()">
            <i class="bi bi-plus"></i> Add New Department
        </button>
    </div>
</div>

<div class="table-container">
    <div class="table-header">
        <h3>All Departments (@Model.Count)</h3>
        <div class="search-box">
            <i class="bi bi-search"></i>
            <!-- Đặt ID chuẩn để JS bắt được -->
            <input type="text" id="searchDepartments" placeholder="Search departments...">
        </div>
    </div>

    <table class="table">
        <thead>
            <tr>
                <th>Title</th>
                <th>Description</th>
                <th>Status</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td><div style="font-weight: 500;">@item.Title</div></td>
                    <td>@item.Description</td>
                    <td>
                        <span class="status-badge @(item.IsActive ? "status-active" : "status-inactive")">
                            @(item.IsActive ? "Active" : "Inactive")
                        </span>
                    </td>
                    <td>
                        <div class="action-buttons">
                            <button class="btn-icon btn-edit" onclick="editDepartment(@item.Id)"><i class="bi bi-pencil"></i></button>
                            <button class="btn-icon btn-delete" onclick="deleteDepartment(@item.Id)"><i class="bi bi-trash"></i></button>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

<!-- Modal Department -->
<div id="departmentModal" class="modal" style="display:none; position:fixed; top:0; left:0; width:100%; height:100%; background:rgba(0,0,0,0.5); z-index:1000;">
    <div class="modal-content" style="background:white; width:500px; margin:100px auto; padding:20px; border-radius:8px;">
        <h3 id="modalTitle">Add Department</h3>
        <input type="hidden" id="deptId">
        <div class="form-group" style="margin-bottom:15px;">
            <label>Title</label>
            <input type="text" id="deptTitle" class="form-control" style="width:100%; padding:8px;">
        </div>
        <div class="form-group" style="margin-bottom:15px;">
            <label>Description</label>
            <textarea id="deptDesc" class="form-control" style="width:100%; padding:8px;"></textarea>
        </div>
        <div style="text-align:right;">
            <button class="btn btn-outline" onclick="closeModal()">Cancel</button>
            <button class="btn btn-primary" onclick="saveDepartment()">Save</button>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // --- CHỨC NĂNG TÌM KIẾM ---
        document.getElementById('searchDepartments')?.addEventListener('input', function(e) {
            const term = e.target.value.toLowerCase();
            document.querySelectorAll('.table tbody tr').forEach(row => {
                // Tìm trong toàn bộ nội dung của dòng
                row.style.display = row.innerText.toLowerCase().includes(term) ? '' : 'none';
            });
        });

        // --- MODAL LOGIC ---
        function openModal() {
            document.getElementById('departmentModal').style.display = 'block';
            document.getElementById('modalTitle').innerText = 'Add Department';
            document.getElementById('deptId').value = '';
            document.getElementById('deptTitle').value = '';
            document.getElementById('deptDesc').value = '';
        }

        function closeModal() {
            document.getElementById('departmentModal').style.display = 'none';
        }

        async function saveDepartment() {
            const id = document.getElementById('deptId').value;
            const data = {
                id: id ? parseInt(id) : 0,
                title: document.getElementById('deptTitle').value,
                description: document.getElementById('deptDesc').value,
                isActive: true
            };
            const url = id ? '/Admin/Admin/UpdateDepartment' : '/Admin/Admin/CreateDepartment';
            try {
                const response = await fetch(url, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(data)
                });
                const result = await response.json();
                if (result.success) location.reload();
                else alert(result.message);
            } catch (e) { alert('Error saving data'); }
        }

        async function editDepartment(id) {
            const response = await fetch(`/Admin/Admin/GetDepartment?id=${id}`);
            const result = await response.json();
            if (result.success) {
                openModal();
                document.getElementById('modalTitle').innerText = 'Edit Department';
                document.getElementById('deptId').value = result.data.id;
                document.getElementById('deptTitle').value = result.data.title;
                document.getElementById('deptDesc').value = result.data.description;
            }
        }

        async function deleteDepartment(id) {
            if (!confirm('Are you sure?')) return;
            const response = await fetch(`/Admin/Admin/DeleteDepartment?id=${id}`, { method: 'POST' });
            if ((await response.json()).success) location.reload();
        }
    </script>
}