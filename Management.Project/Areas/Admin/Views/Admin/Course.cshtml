@model List<Student.Management.Domain.Entities.Course>
@{
    ViewData["Title"] = "Courses";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
    var programs = ViewBag.ProgramList as SelectList;
}

<div class="page-header">
    <div class="page-title"><h1>Courses</h1></div>
    <div class="table-actions">
        <button class="btn btn-primary btn-add" onclick="openCourseModal()"><i class="bi bi-plus"></i> Add Course</button>
    </div>
</div>

<div class="table-container">
    <div class="table-header">
        <h3>All Courses (@Model.Count)</h3>
        <div class="search-box">
            <i class="bi bi-search"></i>
            <!-- Đặt ID chuẩn -->
            <input type="text" id="searchCourses" placeholder="Search courses...">
        </div>
    </div>
    <table class="table">
        <thead>
            <tr>
                <th>Name</th>
                <th>Instructor</th>
                <th>Program</th>
                <th>Price</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td><b>@item.CourseName</b></td>
                    <td>@item.Instructor</td>
                    <td>@(item.Program?.Name)</td>
                    <td>@(item.Price.HasValue? item.Price.Value.ToString("N0") : "0") VND</td>
                    <td>
                        <button class="btn-icon btn-edit" onclick="editCourse(@item.Id)"><i class="bi bi-pencil"></i></button>
                        <button class="btn-icon btn-delete" onclick="deleteCourse(@item.Id)"><i class="bi bi-trash"></i></button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

<!-- Modal Course -->
<div id="courseModal" class="modal" style="display:none; position:fixed; top:0; left:0; width:100%; height:100%; background:rgba(0,0,0,0.5); z-index:1000;">
    <div class="modal-content" style="background:white; width:500px; margin:50px auto; padding:20px; border-radius:8px;">
        <h3 id="courseModalTitle">Add Course</h3>
        <input type="hidden" id="courseId">
        <div class="form-group mb-2"><label>Name</label><input type="text" id="courseName" class="form-control" style="width:100%"></div>
        <div class="form-group mb-2"><label>Instructor</label><input type="text" id="courseInst" class="form-control" style="width:100%"></div>
        <div class="form-group mb-2"><label>Price</label><input type="number" id="coursePrice" class="form-control" style="width:100%"></div>
        <div class="form-group mb-2">
            <label>Program</label>
            <select id="courseProg" class="form-control" asp-items="programs" style="width:100%; padding:8px"><option value="">-- Select Program --</option></select>
        </div>
        <div style="text-align:right; margin-top:20px;">
            <button class="btn btn-outline" onclick="document.getElementById('courseModal').style.display='none'">Cancel</button>
            <button class="btn btn-primary" onclick="saveCourse()">Save</button>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // --- CHỨC NĂNG TÌM KIẾM ---
        document.getElementById('searchCourses')?.addEventListener('input', function(e) {
            const term = e.target.value.toLowerCase();
            document.querySelectorAll('.table tbody tr').forEach(row => {
                row.style.display = row.innerText.toLowerCase().includes(term) ? '' : 'none';
            });
        });

        // --- MODAL LOGIC ---
        function openCourseModal() {
            document.getElementById('courseModal').style.display = 'block';
            document.getElementById('courseModalTitle').innerText = 'Add Course';
            document.getElementById('courseId').value = '';
            document.getElementById('courseName').value = '';
            document.getElementById('courseInst').value = '';
            document.getElementById('coursePrice').value = '';
        }

        async function saveCourse() {
            const id = document.getElementById('courseId').value;
            const data = {
                id: id ? parseInt(id) : 0,
                courseName: document.getElementById('courseName').value,
                instructor: document.getElementById('courseInst').value,
                fullName: document.getElementById('courseInst').value,
                price: parseFloat(document.getElementById('coursePrice').value || 0),
                programId: parseInt(document.getElementById('courseProg').value),
                available: true, isActive: true
            };
            const url = id ? '/Admin/Admin/UpdateCourse' : '/Admin/Admin/CreateCourse';
            const res = await fetch(url, { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(data) });
            if((await res.json()).success) location.reload();
        }

        async function editCourse(id) {
            const res = await fetch(`/Admin/Admin/GetCourse?id=${id}`);
            const result = await res.json();
            if(result.success) {
                openCourseModal();
                document.getElementById('courseModalTitle').innerText = 'Edit Course';
                const d = result.data;
                document.getElementById('courseId').value = d.id;
                document.getElementById('courseName').value = d.courseName;
                document.getElementById('courseInst').value = d.instructor;
                document.getElementById('coursePrice').value = d.price;
                document.getElementById('courseProg').value = d.programId;
            }
        }

        async function deleteCourse(id) {
            if(confirm('Delete?')) {
                const res = await fetch(`/Admin/Admin/DeleteCourse?id=${id}`, { method: 'POST' });
                if((await res.json()).success) location.reload();
            }
        }
    </script>
}