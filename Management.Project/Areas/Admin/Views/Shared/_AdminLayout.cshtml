<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Student Management Admin</title>

    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.8.1/font/bootstrap-icons.css" rel="stylesheet">
    <!-- Link đến file CSS Admin đã chỉnh sửa -->
    <link rel="stylesheet" href="~/css/admin.css" asp-append-version="true" />

    @RenderSection("Styles", required: false)
</head>

<body>
    <div class="admin-layout">
        <!-- Sidebar -->
        <div class="sidebar">
            <div class="sidebar-header">
                <img src="/Image/btec_1710525288.png" alt="BTEC Logo" class="sidebar-logo">
                
            </div>

            <nav class="sidebar-nav">
                <a href="/Admin/Admin" class="nav-item @(ViewContext.RouteData.Values["action"]?.ToString() == "Index" ? "active" : "")">
                    <i class="bi bi-speedometer2"></i> <span>Dashboard</span>
                </a>

                <div class="nav-section">
                    <div style="padding: 0.75rem 1.5rem; font-weight: 600; color: var(--primary); font-size: 0.75rem; text-transform: uppercase;">
                        Management
                    </div>

                    <a href="/Admin/Admin/Users" class="nav-item @(ViewContext.RouteData.Values["action"]?.ToString() == "Users" ? "active" : "")">
                        <i class="bi bi-people"></i> <span>Users</span>
                    </a>
                    <a href="/Admin/Admin/Department" class="nav-item @(ViewContext.RouteData.Values["action"]?.ToString() == "Department" ? "active" : "")">
                        <i class="bi bi-building"></i> <span>Departments</span>
                    </a>
                    <a href="/Admin/Admin/Grade" class="nav-item @(ViewContext.RouteData.Values["action"]?.ToString() == "Grade" ? "active" : "")">
                        <i class="bi bi-mortarboard"></i> <span>Grades</span>
                    </a>
                    <a href="/Admin/Admin/Program" class="nav-item @(ViewContext.RouteData.Values["action"]?.ToString() == "Program" ? "active" : "")">
                        <i class="bi bi-journal-text"></i> <span>Programs</span>
                    </a>
                    <a href="/Admin/Admin/Class" class="nav-item @(ViewContext.RouteData.Values["action"]?.ToString() == "Class" ? "active" : "")">
                        <i class="bi bi-door-open"></i> <span>Classes</span>
                    </a>
                    <a href="/Admin/Admin/Course" class="nav-item @(ViewContext.RouteData.Values["action"]?.ToString() == "Course" ? "active" : "")">
                        <i class="bi bi-book"></i> <span>Courses</span>
                    </a>
                    <a href="/Admin/Admin/Enrollment" class="nav-item @(ViewContext.RouteData.Values["action"]?.ToString() == "Enrollment" ? "active" : "")">
                        <i class="bi bi-clipboard-check"></i> <span>Enrollments</span>
                    </a>
                </div>
            </nav>
        </div>

        
        <!-- Main Content -->
        <div class="main-content">
            <div class="top-bar">
                <div class="search-box">
                    <i class="bi bi-search"></i>
                    <input type="text" id="globalSearch" placeholder="Search users, courses, classes...">
                </div>

                <!-- USER MENU -->
                <div class="user-menu" style="display: flex; align-items: center; gap: 15px;">

                    <!-- Hiển thị thông tin Admin (Không click nữa) -->
                    <div class="user-info" style="display: flex; align-items: center; gap: 8px;">
                        <div class="avatar">A</div>
                        <div style="display: flex; flex-direction: column; line-height: 1.2;">
                            <span style="font-weight: 600; font-size: 0.875rem;">Admin</span>
                            <span style="font-size: 0.75rem; color: var(--text-secondary);">@User.Identity?.Name</span>
                        </div>
                    </div>

                    <!-- QUAN TRỌNG: Phải có asp-area="" để thoát khỏi Admin Area -->
                    <form action="/Account/Logout" method="post" style="margin: 0;">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn-logout" title="Log Out" style="
                            background-color: #fef2f2;
                            color: #ef4444;
                            border: 1px solid #fee2e2;
                            padding: 6px 12px;
                            border-radius: 6px;
                            cursor: pointer;
                            font-size: 0.875rem;
                            font-weight: 500;
                            display: flex;
                            align-items: center;
                            gap: 5px;
                            transition: all 0.2s;">
                            <i class="bi bi-box-arrow-right"></i> Log Out
                        </button>
                    </form>

                </div>
            </div>

            <div class="content">
                @RenderBody()
            </div>
        </div>
    </div>
        

    <!-- Container cho Modal và Thông báo -->
    <div id="modalContainer"></div>
    <div id="notificationContainer"></div>

    <!-- Scripts -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

    @RenderSection("Scripts", required: false)
</body>
</html>