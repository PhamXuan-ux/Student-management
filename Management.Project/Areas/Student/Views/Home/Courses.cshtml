@{
    ViewData["Title"] = "My Courses";
    Layout = "~/Areas/Student/Views/Shared/_StudentLayout.cshtml";
    var currentCourses = ViewBag.CurrentCourses as List<Student.Management.Domain.Entities.ClassStudent>;
    var pastCourses = ViewBag.PastCourses as List<Student.Management.Domain.Entities.ClassStudent>;
    var upcomingCourses = ViewBag.UpcomingCourses as List<Student.Management.Domain.Entities.ClassStudent>;
}

<div class="page-header">
    <div class="page-title">
        <h1> My Courses</h1>
        <p>Total: @ViewBag.TotalCourses courses</p>
    </div>
</div>

<!-- Current Courses -->
@if (currentCourses != null && currentCourses.Any())
{
    <div class="table-container">
        <div class="table-header">
            <h3>📖 Current Courses (@currentCourses.Count)</h3>
        </div>
        <table class="table">
            <thead>
                <tr>
                    <th>Course</th>
                    <th>Class</th>
                    <th>Instructor</th>
                    <th>Program</th>
                    <th>Schedule</th>
                    <th>Current Grade</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var course in currentCourses)
                {
                    <tr>
                        <td>
                            <strong>@course.Class.Course.CourseName</strong><br>
                            <small style="color: var(--text-secondary);">@course.Class.Course.FullName</small>
                        </td>
                        <td>@course.Class.ClassName</td>
                        <td>@course.Class.Teacher.FullName</td>
                        <td>@course.Class.Program?.Name</td>
                        <td>
                            @if (course.Class.Schedules.Any())
                            {
                                var schedule = course.Class.Schedules.First();
                                <span>@schedule.DayOfWeek @schedule.StartTime-@schedule.EndTime</span>
                            }
                            else
                            {
                                <span>No schedule</span>
                            }
                        </td>
                        <td>
                            @if (course.Grade.HasValue)
                            {
                                <span class="status-badge @(course.Grade >= 5 ? "status-active" : "status-inactive")">
                                    @course.Grade.Value.ToString("0.0")
                                </span>
                            }
                            else
                            {
                                <span class="status-badge status-pending">In Progress</span>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

<!-- Past Courses -->
@if (pastCourses != null && pastCourses.Any())
{
    <div class="table-container" style="margin-top: 2rem;">
        <div class="table-header">
            <h3>Completed Courses (@pastCourses.Count)</h3>
        </div>
        <table class="table">
            <thead>
                <tr>
                    <th>Course</th>
                    <th>Class</th>
                    <th>Instructor</th>
                    <th>Program</th>
                    <th>Final Grade</th>
                    <th>Status</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var course in pastCourses)
                {
                    <tr>
                        <td>
                            <strong>@course.Class.Course.CourseName</strong>
                        </td>
                        <td>@course.Class.ClassName</td>
                        <td>@course.Class.Teacher.FullName</td>
                        <td>@course.Class.Program?.Name</td>
                        <td>
                            @if (course.Grade.HasValue)
                            {
                                <span style="font-weight: bold; color: var(--primary);">
                                    @course.Grade.Value.ToString("0.0")
                                </span>
                            }
                            else
                            {
                                <span>N/A</span>
                            }
                        </td>
                        <td>
                            @if (course.Grade.HasValue)
                            {
                                <span class="status-badge @(course.Grade >= 5 ? "status-active" : "status-inactive")">
                                    @(course.Grade >= 5 ? "Passed" : "Failed")
                                </span>
                            }
                            else
                            {
                                <span class="status-badge status-pending">Not Graded</span>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

<!-- Upcoming Courses -->
@if (upcomingCourses != null && upcomingCourses.Any())
{
    <div class="table-container" style="margin-top: 2rem;">
        <div class="table-header">
            <h3>⏳ Upcoming Courses (@upcomingCourses.Count)</h3>
        </div>
        <table class="table">
            <thead>
                <tr>
                    <th>Course</th>
                    <th>Class</th>
                    <th>Instructor</th>
                    <th>Program</th>
                    <th>Start Date</th>
                    <th>End Date</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var course in upcomingCourses)
                {
                    <tr>
                        <td>
                            <strong>@course.Class.Course.CourseName</strong>
                        </td>
                        <td>@course.Class.ClassName</td>
                        <td>@course.Class.Teacher.FullName</td>
                        <td>@course.Class.Program?.Name</td>
                        <td>
                            @if (course.Class.StartDate.HasValue)
                            {
                                <span>@course.Class.StartDate.Value.ToString("dd/MM/yyyy")</span>
                            }
                            else
                            {
                                <span>N/A</span>
                            }
                        </td>
                        <td>
                            @if (course.Class.EndDate.HasValue)
                            {
                                <span>@course.Class.EndDate.Value.ToString("dd/MM/yyyy")</span>
                            }
                            else
                            {
                                <span>N/A</span>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@if (ViewBag.TotalCourses == 0)
{
    <div class="table-container">
        <div class="table-header">
            <h3>My Courses</h3>
        </div>
        <div style="padding: 3rem; text-align: center; color: var(--text-secondary);">
            <i class="bi bi-book" style="font-size: 3rem; margin-bottom: 1rem;"></i>
            <h3>No courses enrolled</h3>
            <p>You are not enrolled in any courses yet.</p>
        </div>
    </div>
}