@{
    ViewData["Title"] = "My Grades";
    Layout = "~/Areas/Student/Views/Shared/_StudentLayout.cshtml";
    var detailedGrades = ViewBag.DetailedGrades as List<Student.Management.Domain.Entities.Grade>;
    var classGrades = ViewBag.ClassGrades as List<dynamic>;
}

<div class="page-header">
    <div class="page-title">
        <h1> My Grades</h1>
        <p>Current GPA: <strong>@ViewBag.GPA</strong></p>
    </div>
</div>

<!-- Grade Statistics -->
<div class="stats-grid">
    <div class="stat-card">
        <div class="stat-card-header">
            <h3>Total Courses</h3>
            <div class="stat-icon"><i class="bi bi-book"></i></div>
        </div>
        <div class="stat-number">@ViewBag.TotalCourses</div>
        <div class="stat-label">Enrolled</div>
    </div>

    <div class="stat-card">
        <div class="stat-card-header">
            <h3>Passed</h3>
            <div class="stat-icon"><i class="bi bi-check-circle"></i></div>
        </div>
        <div class="stat-number">@ViewBag.PassedCourses</div>
        <div class="stat-label">Completed</div>
    </div>

    <div class="stat-card">
        <div class="stat-card-header">
            <h3>Failed</h3>
            <div class="stat-icon"><i class="bi bi-x-circle"></i></div>
        </div>
        <div class="stat-number">@ViewBag.FailedCourses</div>
        <div class="stat-label">Need to retake</div>
    </div>

    @* <div class="stat-card">
        <div class="stat-card-header">
            <h3>In Progress</h3>
            <div class="stat-icon"><i class="bi bi-clock"></i></div>
        </div>
        <div class="stat-number">@ViewBag.InProgressCourses</div>
        <div class="stat-label">Currently studying</div>
    </div> *@
</div>

