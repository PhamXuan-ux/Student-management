</div> *@

<!-- Detailed Grades -->
@if (detailedGrades != null && detailedGrades.Any())
{
    <div class="table-container" style="margin-top: 2rem;">
        <div class="table-header">
            <h3>Detailed Grade History</h3>
        </div>
        <table class="table">
            <thead>
                <tr>
                    <th>Date</th>
                    <th>Course</th>
                    <th>Grade Type</th>
                    <th>Score</th>
                    <th>Max Score</th>
                    <th>Weight</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var grade in detailedGrades)
                {
                    <tr>
                        <td>@grade.CreatedDate.ToString("MMM dd, yyyy")</td>
                        <td>@grade.Class?.Course?.CourseName</td>
                        <td>@grade.GradeType</td>
                        <td>
                            <span style="font-weight: bold; color: var(--primary);">
                                @grade.Score.ToString("0.0")
                            </span>
                        </td>
                        <td>@grade.MaxScore.ToString("0.0")</td>
                        <td>@grade.Weight%</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}