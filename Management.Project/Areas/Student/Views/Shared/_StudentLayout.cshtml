<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Student Portal</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.8.1/font/bootstrap-icons.css" rel="stylesheet">
    <link rel="stylesheet" href="~/css/admin.css?v=15.0" />
</head>
<body>
    <div class="admin-layout">
        <!-- Sidebar -->
        <div class="sidebar">
            <div class="sidebar-header">
                <img src="/Image/btec_1710525288.png" alt="Logo" class="sidebar-logo">
                <span class="sidebar-brand-text">Student Portal</span>
            </div>
            <nav class="sidebar-nav">
                <a href="/Student/Home/Index" class="nav-item @(ViewContext.RouteData.Values["action"]?.ToString() == "Index" ? "active" : "")">
                    <i class="bi bi-house"></i> <span>Dashboard</span>
                </a>
                <a href="/Student/Home/Schedule" class="nav-item @(ViewContext.RouteData.Values["action"]?.ToString() == "Schedule" ? "active" : "")">
                    <i class="bi bi-calendar-week"></i> <span>Class Schedule</span>
                </a>
                <a href="/Student/Home/Grades" class="nav-item @(ViewContext.RouteData.Values["action"]?.ToString() == "Grades" ? "active" : "")">
                    <i class="bi bi-journal-check"></i> <span>My Grades</span>
                </a>
                <a href="/Student/Home/Courses" class="nav-item @(ViewContext.RouteData.Values["action"]?.ToString() == "Courses" ? "active" : "")">
                    <i class="bi bi-book"></i> <span>My Courses</span>
                </a>
                <a href="/Student/Home/Profile" class="nav-item @(ViewContext.RouteData.Values["action"]?.ToString() == "Profile" ? "active" : "")">
                    <i class="bi bi-person"></i> <span>Profile</span>
                </a>
                @* Nếu cần điểm danh *@
                @* <a href="/Student/Home/Attendance" class="nav-item @(ViewContext.RouteData.Values["action"]?.ToString() == "Attendance" ? "active" : "")">
                    <i class="bi bi-clipboard-check"></i> <span>Attendance</span>
                </a> *@
            </nav>
        </div>

        <!-- Main Content -->
        <div class="main-content">
            <!-- Top Bar -->
            <div class="top-bar">
                <div>
                    <h4>Welcome, Student</h4>
                    <small style="color: var(--text-secondary);">Academic Portal</small>
                </div>
                <div class="user-menu">
                    <form action="/Account/Logout" method="post" style="margin: 0;">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn-logout" title="Log Out" style="
                            background-color: #fef2f2;
                            color: #ef4444;
                            border: 1px solid #fee2e2;
                            padding: 6px 12px;
                            border-radius: 6px;
                            cursor: pointer;
                            font-size: 0.875rem;
                            font-weight: 500;
                            display: flex;
                            align-items: center;
                            gap: 5px;
                            transition: all 0.2s;">
                            <i class="bi bi-box-arrow-right"></i> Log Out
                        </button>
                    </form>
                </div>
            </div>

            <!-- Content -->
            <div class="content">
                <!-- Notification Messages -->
                @if (TempData["Success"] != null)
                {
                    <div class="notification success" style="background:#dcfce7; color:#166534; padding:1rem; border-radius:8px; margin-bottom:1rem;">
                        @TempData["Success"]
                    </div>
                }
                @if (TempData["Error"] != null)
                {
                    <div class="notification error" style="background:#fef2f2; color:#991b1b; padding:1rem; border-radius:8px; margin-bottom:1rem;">
                        @TempData["Error"]
                    </div>
                }

                @RenderBody()
            </div>
        </div>
    </div>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    @RenderSection("Scripts", required: false)
</body>
</html>