<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Student Management System</title>

    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />

    <!-- Account CSS -->
    <link rel="stylesheet" href="~/css/account.css" asp-append-version="true" />

    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    <!-- Header -->
    <header>
        <nav class="navbar navbar-expand-lg navbar-dark bg-primary">
            <div class="container">
                <a class="navbar-brand" href="/">
                    <i class="fas fa-graduation-cap me-2"></i>
                    Student Management
                </a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="navbarNav">
                    <ul class="navbar-nav me-auto">
                        @if (User.Identity.IsAuthenticated)
                        {
                            <li class="nav-item">
                                <a class="nav-link" href="/Home">
                                    <i class="fas fa-home me-1"></i>Home
                                </a>
                            </li>

                            <!-- Dynamic menu based on role -->
                            @if (User.IsInRole("Admin"))
                            {
                                <li class="nav-item">
                                    <a class="nav-link" href="/Admin/Admin">
                                        <i class="fas fa-cog me-1"></i>Admin Dashboard
                                    </a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" href="/Admin/Users">
                                        <i class="fas fa-users me-1"></i>Manage Users
                                    </a>
                                </li>
                            }
                            else if (User.IsInRole("Teacher"))
                            {
                                <li class="nav-item">
                                    <a class="nav-link" href="/Teacher/Home/Index">
                                        <i class="fas fa-chalkboard-teacher me-1"></i>Teacher Dashboard
                                    </a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" href="/Teacher/Courses">
                                        <i class="fas fa-book me-1"></i>Courses
                                    </a>
                                </li>
                            }
                            else if (User.IsInRole("Student"))
                            {
                                <li class="nav-item">
                                    <a class="nav-link" href="/Student/Home/Index">
                                        <i class="fas fa-user-graduate me-1"></i>Student Dashboard
                                    </a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" href="/Student/Courses">
                                        <i class="fas fa-book me-1"></i>My Courses
                                    </a>
                                </li>
                            }
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link" href="/Home">
                                    <i class="fas fa-home me-1"></i>Home
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" href="/Account">
                                    <i class="fas fa-sign-in-alt me-1"></i>Login
                                </a>
                            </li>
                        }
                    </ul>

                    <!-- User Info & Logout -->
                    @if (User.Identity.IsAuthenticated)
                    {
                        <ul class="navbar-nav">
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle" href="#" id="navbarDropdown" role="button" data-bs-toggle="dropdown">
                                    <i class="fas fa-user-circle me-1"></i>
                                    @User.Identity.Name
                                </a>
                                <ul class="dropdown-menu dropdown-menu-end">
                                    <li>
                                        <a class="dropdown-item" href="/Profile">
                                            <i class="fas fa-user me-2"></i>Profile
                                        </a>
                                    </li>
                                    <li><hr class="dropdown-divider"></li>
                                    <li>
                                        <form asp-controller="Account" asp-action="Logout" method="post" id="logoutForm">
                                            <button type="submit" class="dropdown-item text-danger">
                                                <i class="fas fa-sign-out-alt me-2"></i>Logout
                                            </button>
                                        </form>
                                    </li>
                                </ul>
                            </li>
                        </ul>
                    }
                </div>
            </div>
        </nav>
    </header>

    <!-- Main Content -->
    <main role="main" class="container-fluid px-0">
        @RenderBody()
    </main>

    <!-- Footer -->
    <footer class="border-top footer text-muted mt-5">
        <div class="container py-4">
            <div class="row">
                <div class="col-md-6">
                    <p>&copy; 2024 Student Management System. All rights reserved.</p>
                </div>
                <div class="col-md-6 text-end">
                    <a href="/Privacy" class="text-muted me-3">Privacy Policy</a>
                    <a href="/Terms" class="text-muted">Terms of Service</a>
                </div>
            </div>
        </div>
    </footer>

    <!-- Scripts -->
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

    <!-- Account JS -->
    <script src="~/js/account.js" asp-append-version="true"></script>

    <!-- Site JS -->
    <script src="~/js/site.js" asp-append-version="true"></script>

    <!-- Auto-redirect script for authenticated users -->
    <script>
        $(document).ready(function() {
            // Handle logout form submission
            $('#logoutForm').on('submit', function(e) {
                if (!confirm('Are you sure you want to logout?')) {
                    e.preventDefault();
                }
            });

            // Auto-redirect if already authenticated (except on account page)
            if (window.location.pathname !== '/Account' &&
                window.location.pathname !== '/Account/Index' &&
                !window.location.pathname.includes('/Account/')) {

                fetch('/Account/CheckAuth')
                    .then(response => response.json())
                    .then(data => {
                        if (data.isAuthenticated) {
                            console.log('User already logged in:', data.user);

                            // If we're on home page, redirect to appropriate dashboard
                            if (window.location.pathname === '/' || window.location.pathname === '/Home') {
                                let redirectUrl = '/Home/Index';
                                if (data.user.role === 'Admin' || (data.roles && data.roles.includes('Admin'))) {
                                    redirectUrl = '/Admin/Admin';
                                } else if (data.user.role === 'Teacher' || (data.roles && data.roles.includes('Teacher'))) {
                                    redirectUrl = '/Teacher/Home/Index';
                                } else if (data.user.role === 'Student' || (data.roles && data.roles.includes('Student'))) {
                                    redirectUrl = '/Student/Home/Index';
                                }

                                console.log('Auto-redirecting to:', redirectUrl);
                                window.location.href = redirectUrl;
                            }
                        }
                    })
                    .catch(error => {
                        console.error('Auth check failed:', error);
                    });
            }
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>